# Порт сервера
PORT=3000

# Токен бота от @BotFather (без него веб-часть всё равно работает)
BOT_TOKEN=

# Telegram ID администраторов через запятую (кто может добавлять товар через бота)
# Узнать свой ID можно у @userinfobot
ADMIN_TELEGRAM_IDS=

# Пароль для входа в админку приложения (/admin)
ADMIN_PASSWORD=atiya

# Номер WhatsApp тёти, куда уходят заказы. Только цифры с кодом страны.
# Таджикистан: 992XXXXXXXXX
WHATSAPP_NUMBER=

# Публичный HTTPS-адрес приложения (нужен для кнопки Mini App в боте)
PUBLIC_URL=

# Название магазина и валюта
BRAND_NAME=Atiya
CURRENCY=смн
